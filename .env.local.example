NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# --- Sugestões por IA (somente servidor; nunca NEXT_PUBLIC_*) ---
# true/false — se omitido, habilita quando houver AI_API_KEY
AI_SUGGESTIONS_ENABLED=true
# Chave do provedor (OpenAI, Groq, etc.)
AI_API_KEY=
# Base URL OpenAI-compatible (padrão OpenAI)
# Groq: https://api.groq.com/openai/v1
AI_BASE_URL=https://api.openai.com/v1
# Modelo barato/rápido para sugestões curtas
AI_MODEL=gpt-4o-mini
AI_TIMEOUT_MS=20000
AI_MAX_RETRIES=1
AI_TEMPERATURE=0.3
AI_MAX_TOKENS=800
# Limite de chamadas por usuário / hora
AI_RATE_LIMIT_PER_USER_HOUR=30
