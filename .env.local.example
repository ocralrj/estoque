NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# --- Sugestões por IA (somente servidor; nunca NEXT_PUBLIC_*) ---
# Padrão: Google Gemini (grátis) — https://aistudio.google.com/apikey
AI_SUGGESTIONS_ENABLED=true
AI_PROVIDER=gemini
GEMINI_API_KEY=
# Modelos grátis comuns: gemini-2.0-flash | gemini-1.5-flash | gemini-2.5-flash
AI_MODEL=gemini-2.0-flash
AI_TIMEOUT_MS=25000
AI_MAX_RETRIES=1
AI_TEMPERATURE=0.3
AI_MAX_TOKENS=800
AI_RATE_LIMIT_PER_USER_HOUR=40

# Alternativa OpenAI/Groq (opcional):
# AI_PROVIDER=openai
# AI_API_KEY=
# AI_BASE_URL=https://api.openai.com/v1
# AI_MODEL=gpt-4o-mini
